#!/usr/bin/env python3
from subprocess import SubprocessError, check_output, run
from ..common import update_checker_common as common
import re

updated_regex = re.compile('(\d+)\s+to\supgrade,')
appname="Software update checker"

def apt_update():
  try:
    run(["apt-get", "update"], capture_output=True)
  except SubprocessError:
    common.error_notification(title="Failed to retrieve package update lists", errorstr=SubprocessError, app=appname)
    raise

def apt_installable():
  try:
    upgradeable = updated_regex.search(check_output(["apt-get", "dist-upgrade", "--simulate", "--purge", "--auto-remove"]).decode('utf-8')).group(1)
  except SubprocessError:
    common.error_notification(title="Failed to determine number of upgrades", error_str=SubprocessError,  app=appname)
    raise
  return upgradeable

def main():
  apt_update()
  sw_upgrades = apt_installable()

  software_str = "Software upgrade available" if int(sw_upgrades) == 1 else (sw_upgrades) + " software upgrades available\nRun `aptupdater` to install"

  common.update_notifier(app=appname, title="Software updates available!", msg=software_str)

if __name__ == "__main__":
    main()