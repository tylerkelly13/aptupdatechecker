#!/usr/bin/make -f
# See debhelper(7) (uncomment to enable)
# output every command that modifies files on the build system.
#export DH_VERBOSE = 1

# see FEATURE AREAS in dpkg-buildflags(1)
#export DEB_BUILD_MAINT_OPTIONS = hardening=+all

# see ENVIRONMENT in dpkg-buildflags(1)
# package maintainers to append CFLAGS
#export DEB_CFLAGS_MAINT_APPEND  = -Wall -pedantic
# package maintainers to append LDFLAGS
#export DEB_LDFLAGS_MAINT_APPEND = -Wl,--as-needed

VERSION = $(shell sed -rn "s/version\s+=\s+\"([^\"]+)\"/\1/p" pyproject.toml)

%:
	dh $@

override_dh_fixperms:
	dh_fixperms

# dh_make generated override targets
# This is example for Cmake (See https://bugs.debian.org/641051 )
#override_dh_auto_configure:
#	dh_auto_configure -- \
#	-DCMAKE_LIBRARY_PATH=$(DEB_HOST_MULTIARCH)

override_dh_installsystemd:
	dh_installsystemd aptupdatechecker.service
	dh_installsystemd --no-start aptupdatechecker_apt_update_checker.service aptupdatechecker_autoclean.service aptupdatechecker_autoremove.service aptupdatechecker_firmware_update_checker.service
	dh_installsystemd aptupdatechecker_apt_update_checker.timer aptupdatechecker_autoclean.timer aptupdatechecker_autoremove.timer aptupdatechecker_firmware_update_checker.timer

override_dh_gencontrol:
	dh_gencontrol -- -v$(VERSION)